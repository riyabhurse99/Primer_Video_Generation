# ─── LLM ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── TTS ───────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id        # pick a voice from ElevenLabs dashboard

# ─── GROOT (reverse-engineered slide generator) ────
# Paste the full Cookie header string from DevTools → Headers tab of any groot request
# Open https://groot-pied.vercel.app, generate a lesson, open DevTools → Network
# Click any /api/generate/* request → Headers → copy the Cookie value
GROOT_COOKIES=

# ─── TTS BACKEND ───────────────────────────────────
# gtts       = free Google TTS (no key needed, recommended)
# elevenlabs = ElevenLabs API (needs ELEVENLABS_API_KEY)
# mock       = silent audio (for testing without audio)
TTS_BACKEND=gtts

# ─── OPENMAIC (legacy, replaced by groot) ──────────
OPENMAIC_BASE_URL=http://localhost:3000
OPENMAIC_API_KEY=

# ─── STORAGE ───────────────────────────────────────
STORAGE_BACKEND=local                          # local | s3
LOCAL_STORAGE_PATH=./output

# AWS S3 (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=ap-south-1

# ─── PIPELINE MODE ─────────────────────────────────
USE_MOCKS=true                                 # true = use mocks (no API keys needed)
                                               # false = use real APIs
